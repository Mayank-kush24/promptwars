# =============================================================================
# CDI module — minimum you must set: MODULE_ID + JWT + REG_SECRET + PORTAL URL
# Aliases: H2S_CDI_* or JARVIS_* (see h2s_cdi_auth._env_first — first non-empty wins)
# =============================================================================
# =============================================================================
# STEP 1 of 2 — Fill in THESE 3 values (everything else is pre-filled)
# =============================================================================

# Slug for this app — lowercase, no spaces (e.g. "myapp", "hr-portal")
# Must match: the service slug you add in Nginx Config in the portal
#             and the APPLICATION_ROOT / BASE_URL below
# (alias: JARVIS_MODULE_ID)
H2S_CDI_MODULE_ID=myapp

# Human-readable name shown in the portal admin UI
MODULE_NAME=My App

# Port this app will listen on — pick one not already in use
PORT=5100

# =============================================================================
# STEP 2 of 2 — Copy 2 secrets from the portal .env
# =============================================================================

# Copy from portal .env — must match exactly (same bytes as portal)
# H2S_CDI_JWT_SECRET or JARVIS_JWT_SECRET
H2S_CDI_JWT_SECRET=

# Portal MODULE_REGISTRATION_SECRET — same as H2S_CDI_REGISTRATION_SECRET or JARVIS_REGISTRATION_SECRET
H2S_CDI_REGISTRATION_SECRET=

# =============================================================================
# Pre-filled — update only if your setup is different
# =============================================================================

# Public portal URL (registration + fallbacks). If this is localhost and users
# open the app via nginx, login/dashboard links use X-Forwarded-Host automatically.
H2S_CDI_URL=http://h2s.tech

# Internal URL for server-to-server registration (bypasses nginx)
H2S_CDI_INTERNAL_URL=http://localhost:5050

# Optional: force browser links when not using stock CDI nginx headers
# H2S_CDI_PUBLIC_URL=https://h2s.tech

# Path prefix served by nginx — must match H2S_CDI_MODULE_ID
APPLICATION_ROOT=/myapp
BASE_URL=http://localhost:5100

SECRET_KEY=change-me-in-production
DEBUG=false
