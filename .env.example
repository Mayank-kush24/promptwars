DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/prompt_wars
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
SESSION_SECRET=change-me-session
# Optional: if set, /admin requires login
# ADMIN_PASSWORD=

# Debugger / auto-reload (1=on, 0=off). Defaults: debug ON, reloader follows debug.
FLASK_DEBUG=1
FLASK_USE_RELOADER=1

# In-person program id: funnel filters + Main Data Center import/stats (single Vision program)
DEFAULT_IN_PERSON_EVENT_ID=1
DEFAULT_VIRTUAL_EVENT_ID=2
DEFAULT_CHALLENGE_ID=1

# Master Audit Log (see audit/ package + database/audit.sql).
# AUDIT_ENABLED=0 disables the entire audit subsystem (NOT recommended in prod).
# AUDIT_QUEUE_MAXSIZE: max in-flight events buffered before back-pressure kicks in.
# AUDIT_FLUSH_INTERVAL_MS: how often the worker thread drains the queue.
# AUDIT_FLUSH_BATCH: max rows per bulk INSERT into audit.audit_events.
# AUDIT_QUEUE_BLOCK_MS: how long a request will block when the queue is full
#   before recording a SINK_OVERFLOW marker (never silently drops).
# AUDIT_STRICT_BOOT_CHECK=1 makes startup fail-fast if the audit schema or the
#   ddl_command_end EVENT TRIGGER is missing (use after running run_init_sql.py).
AUDIT_ENABLED=1
AUDIT_QUEUE_MAXSIZE=100000
AUDIT_FLUSH_INTERVAL_MS=250
AUDIT_FLUSH_BATCH=500
AUDIT_QUEUE_BLOCK_MS=500
AUDIT_STRICT_BOOT_CHECK=0
