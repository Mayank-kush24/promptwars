DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/prompt_wars
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
SESSION_SECRET=change-me-session

# --- Hack2skill CDI (JARVIS) — copy secrets from portal .env; never commit .env ---
# Slug / module id (must match nginx mount and portal module)
H2S_CDI_MODULE_ID=prompt-wars
# Display name in portal
MODULE_NAME=Prompt Wars
# Base URL of this app (used for portal registration), e.g. http://127.0.0.1:5000
BASE_URL=http://127.0.0.1:5000
# Path prefix when served behind CDI nginx (often same as H2S_CDI_MODULE_ID).
# If unset, ``/`` + H2S_CDI_MODULE_ID is used to strip PATH_INFO at WSGI level (required for /slug/ routes).
APPLICATION_ROOT=/prompt-wars
# Portal (browser redirects; registration fallback)
H2S_CDI_URL=https://h2s.tech
# Server-to-server registration (recommended)
H2S_CDI_INTERNAL_URL=http://127.0.0.1:5050
# Optional: force portal links when not using stock proxy headers
# H2S_CDI_PUBLIC_URL=https://h2s.tech
# Copy from portal — must match exactly
H2S_CDI_JWT_SECRET=
H2S_CDI_REGISTRATION_SECRET=

# Debugger / auto-reload (1=on, 0=off). Defaults: debug ON, reloader follows debug.
FLASK_DEBUG=1
FLASK_USE_RELOADER=1

# In-person program id: funnel filters + Main Data Center import/stats (single Vision program)
DEFAULT_IN_PERSON_EVENT_ID=1
DEFAULT_VIRTUAL_EVENT_ID=2
# Must match an existing challenges.id for the virtual event (Virtual dashboard + /api/leaderboard). If wrong, you get 404 on leaderboard refresh.
DEFAULT_CHALLENGE_ID=1

# Master Audit Log (see audit/ package + database/audit.sql).
# AUDIT_ENABLED=0 disables the entire audit subsystem (NOT recommended in prod).
# AUDIT_QUEUE_MAXSIZE: max in-flight events buffered before back-pressure kicks in.
# AUDIT_FLUSH_INTERVAL_MS: how often the worker thread drains the queue.
# AUDIT_FLUSH_BATCH: max rows per bulk INSERT into audit.audit_events.
# AUDIT_QUEUE_BLOCK_MS: how long a request will block when the queue is full
#   before recording a SINK_OVERFLOW marker (never silently drops).
# AUDIT_STRICT_BOOT_CHECK=1 makes startup fail-fast if the audit schema or the
#   ddl_command_end EVENT TRIGGER is missing (use after running run_init_sql.py).
AUDIT_ENABLED=1
AUDIT_QUEUE_MAXSIZE=100000
AUDIT_FLUSH_INTERVAL_MS=250
AUDIT_FLUSH_BATCH=500
AUDIT_QUEUE_BLOCK_MS=500
AUDIT_STRICT_BOOT_CHECK=0
# App-layer SQL audit: set to 1 to log SELECT/TXN statements (default off = faster reads).
# AUDIT_SQL_SELECTS=0
# When 1, never block the request thread on a full audit queue (drops oldest queued events).
AUDIT_QUEUE_DROP_OLDEST=1

# --- Production / performance (optional) ---
# DB pool (SQLAlchemy QueuePool)
# DB_POOL_SIZE=32
# DB_POOL_OVERFLOW=32
# DB_POOL_RECYCLE=1800
# DB_POOL_TIMEOUT=10
# In-process TTL caches (single Waitress process)
# PW_CACHE_HOT_TTL_SEC=5
# PW_CACHE_WARM_TTL_SEC=60
# PW_CACHE_HOT_MAX=2000
# PW_CACHE_WARM_MAX=500
# Waitress (used when FLASK_DEBUG=0)
# WAITRESS_THREADS=64
# WAITRESS_CHANNEL_TIMEOUT=120
# WAITRESS_CLEANUP_INTERVAL=30
# Slow request log (optional path; logs requests >= PW_SLOW_REQUEST_MS)
# PW_SLOW_REQUEST_LOG=logs/prompt_wars_slow.log
# PW_SLOW_REQUEST_MS=500
# Reserved thread pool size for future async import offload (imports are still synchronous today).
# PW_IMPORT_THREAD_POOL=2

# ── Hawkeye External RSVP API ──────────────────────────────────────────────
# Base URL for Hawkeye API (no trailing slash). The integration calls
#   GET {HAWKEYE_BASE_URL}/api/api/integrations/hawkeye/events/<eventTag>/stats?includeEmails=1
# Defaults to https://hawkeye.hack2skill.com when blank.
HAWKEYE_BASE_URL=https://hawkeye.hack2skill.com
# API key sent as: Authorization: Bearer <key>  (leave blank if not required)
HAWKEYE_API_KEY=
